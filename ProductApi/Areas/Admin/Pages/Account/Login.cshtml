@page
@model ProductApi.Areas.Admin.Pages.Account.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Admin Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Admin Login - Event Board</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="card shadow-sm" style="width: 100%; max-width: 380px;">
            <div class="card-body">
                <h4 class="card-title mb-3">Admin Login</h4>
                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }
                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Form.Username" class="form-label"></label>
                        <input asp-for="Form.Username" class="form-control" autocomplete="username" />
                        <span asp-validation-for="Form.Username" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Form.Password" class="form-label"></label>
                        <input asp-for="Form.Password" type="password" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Form.Password" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Log in</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>
