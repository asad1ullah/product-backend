@page
@model ProductApi.Areas.Admin.Pages.Events.CreateModel
@{
    ViewData["Title"] = "Create Event";
}

<h2 class="mb-4">Create Event</h2>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" enctype="multipart/form-data" class="row g-3">
    <div class="col-md-6">
        <label asp-for="Form.Title" class="form-label"></label>
        <input asp-for="Form.Title" class="form-control" />
        <span asp-validation-for="Form.Title" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Form.Location" class="form-label"></label>
        <input asp-for="Form.Location" class="form-control" />
    </div>
    <div class="col-md-12">
        <label asp-for="Form.Description" class="form-label"></label>
        <textarea asp-for="Form.Description" class="form-control"></textarea>
    </div>
    <div class="col-md-3">
        <label asp-for="Form.StartDate" class="form-label"></label>
        <input asp-for="Form.StartDate" type="datetime-local" class="form-control" />
        <span asp-validation-for="Form.StartDate" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Form.EndDate" class="form-label"></label>
        <input asp-for="Form.EndDate" type="datetime-local" class="form-control" />
        <span asp-validation-for="Form.EndDate" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Form.Capacity" class="form-label"></label>
        <input asp-for="Form.Capacity" type="number" class="form-control" />
        <span asp-validation-for="Form.Capacity" class="text-danger"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="Form.Price" class="form-label"></label>
        <input asp-for="Form.Price" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Form.Price" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Form.CategoryId" class="form-label">Category</label>
        <select asp-for="Form.CategoryId" asp-items="Model.Categories" class="form-select">
            <option value="">-- Select category --</option>
        </select>
        <span asp-validation-for="Form.CategoryId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Form.OrganizerId" class="form-label">Organizer</label>
        <select asp-for="Form.OrganizerId" asp-items="Model.Organizers" class="form-select">
            <option value="">-- Select organizer --</option>
        </select>
        <span asp-validation-for="Form.OrganizerId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Form.Image" class="form-label">Event Image</label>
        <input asp-for="Form.Image" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Create</button>
        <a class="btn btn-secondary" asp-page="/Events/Index">Cancel</a>
    </div>
</form>
