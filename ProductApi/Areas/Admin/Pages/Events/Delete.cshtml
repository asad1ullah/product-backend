@page "{id:int}"
@model ProductApi.Areas.Admin.Pages.Events.DeleteModel
@{
    ViewData["Title"] = "Delete Event";
}

<h2 class="mb-4">Delete Event</h2>

<div class="alert alert-warning">
    Are you sure you want to delete <strong>@Model.Event?.Title</strong>? This cannot be undone.
</div>

<form method="post">
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-page="/Events/Index">Cancel</a>
</form>
